# OCR Platform Backend Configuration

# Database (path relative to project root)
DATABASE_URL=sqlite:///../data/ocr_platform.db

# MinIO (Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_RESULTS=results
MINIO_BUCKET_DELETED=deleted
MINIO_SECURE=false

# NATS (Message Queue)
NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=OCR_JOBS
NATS_DLQ_STREAM_NAME=OCR_DLQ

# Authentication
SECRET_KEY=your-secret-key-change-in-production
SESSION_EXPIRE_HOURS=24

# Service Registration (format: service_id:access_key:methods:tiers;...)
# Example: worker-text-tier0:sk_text_tier0:text_raw:0;worker-layout-tier1:sk_layout_tier1:layout:1
SEED_SERVICES=worker-ocr-default:sk_test_worker:text_raw:0
