# Tesseract Worker - Specific Config
# Copy to .env: cp .env.example .env
# Overrides shared values from root .env

# Identity
WORKER_SERVICE_TYPE=ocr-tesseract
WORKER_DISPLAY_NAME=Tesseract OCR (CPU)
WORKER_DESCRIPTION=Tesseract-based text extraction (CPU-only)

# Credentials
WORKER_ACCESS_KEY=sk_local_tesseract

# Capabilities
WORKER_SUPPORTED_FORMATS=txt,json

# OCR Settings
OCR_ENGINE=tesseract
USE_GPU=false
OCR_LANG=vie
