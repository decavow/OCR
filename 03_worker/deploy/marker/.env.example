# Marker Worker - Specific Config
# Copy to .env: cp .env.example .env
# Overrides shared values from root .env

# Identity
WORKER_SERVICE_TYPE=marker
WORKER_DISPLAY_NAME=ocr_text_formatted(marker)
WORKER_DESCRIPTION=Marker (Surya OCR) formatted text extraction with structure preservation (headings, tables, lists)

# Credentials
WORKER_ACCESS_KEY=sk_local_marker

# Queue routing
WORKER_FILTER_SUBJECT=ocr.ocr_marker.tier0

# Capabilities
WORKER_ALLOWED_METHODS=ocr_marker
WORKER_ALLOWED_TIERS=0
WORKER_SUPPORTED_FORMATS=md,html,json

# OCR Settings
OCR_ENGINE=marker
USE_GPU=true
OCR_LANG=vi

# Marker-specific (batch sizes set before surya import)
# VRAM budget: batch=8 → ~5GB peak, batch=4 → ~3GB peak
MARKER_BATCH_SIZE=8
INFERENCE_RAM=8
MARKER_USE_LLM=false
# GOOGLE_API_KEY=  # Required if MARKER_USE_LLM=true
