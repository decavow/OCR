# PaddleOCR Worker - Specific Config
# Copy to .env: cp .env.example .env
# Overrides shared values from root .env

# Identity
WORKER_SERVICE_TYPE=ocr-paddle
WORKER_DISPLAY_NAME=PaddleOCR (GPU)
WORKER_DESCRIPTION=PaddleOCR-based text extraction with GPU acceleration

# Credentials
WORKER_ACCESS_KEY=sk_local_paddle

# Capabilities
WORKER_SUPPORTED_FORMATS=txt,json

# OCR Settings
OCR_ENGINE=paddle
USE_GPU=true
OCR_LANG=vie
