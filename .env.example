# OCR Platform - Shared Environment Variables
#
# This file is loaded by:
#   1. Root docker-compose.yml (for ${VAR} substitution)
#   2. All worker compose files (via env_file: ../../.env)
#
# Copy to .env: cp .env.example .env

# ============================================================
# INFRASTRUCTURE (root docker-compose.yml)
# ============================================================

# --- MinIO (Object Storage) ---
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- NATS (Message Queue) ---
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# ============================================================
# BACKEND (root docker-compose.yml)
# ============================================================

BACKEND_PORT=8080

# Storage (uses container_name for cross-compose compatibility)
MINIO_ENDPOINT=ocr-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_UPLOADS=uploads
MINIO_BUCKET_RESULTS=results
MINIO_BUCKET_DELETED=deleted

# Queue
NATS_URL=nats://ocr-nats:4222
NATS_STREAM_NAME=OCR_JOBS

# Database
DATABASE_URL=sqlite:///./data/ocr_fresh.db

# Service Registry (DEV only)
# Format: type_id:access_key:methods:tiers (semicolon-separated)
SEED_SERVICES=ocr-paddle:sk_local_paddle:ocr_paddle_text:0;ocr-tesseract:sk_local_tesseract:ocr_tesseract_text:0;ocr-paddle-vl:sk_local_paddle_vl:structured_extract:0:json,md,txt

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Auth
SECRET_KEY=dev-secret-key-change-in-production

# ============================================================
# WORKER SHARED (loaded by all workers via env_file)
# ============================================================

# Connections
# Docker worker → Docker backend: http://ocr-backend:8000
# Docker worker → Local backend:  http://host.docker.internal:8080
FILE_PROXY_URL=http://host.docker.internal:8080/api/v1/internal/file-proxy
ORCHESTRATOR_URL=http://host.docker.internal:8080/api/v1/internal

# Capabilities (default for all workers)
WORKER_FILTER_SUBJECT=ocr.ocr_paddle_text.tier0
WORKER_ALLOWED_METHODS=ocr_paddle_text
WORKER_ALLOWED_TIERS=0

# Runtime
LOG_LEVEL=INFO
HEARTBEAT_INTERVAL_MS=30000
JOB_TIMEOUT_SECONDS=300

# ============================================================
# FRONTEND
# ============================================================

VITE_API_BASE_URL=http://localhost:8080/api/v1
